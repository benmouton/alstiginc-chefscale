{
  "expo": {
    "name": "Chef Scale",
    "slug": "chefscale",
    "version": "1.0.2",
    "description": "Scale recipes and manage ingredient costs. Offline-first, with cloud sync capabilities.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chefscale",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alstiginc.chefscale",
      "buildNumber": "10",
      "infoPlist": {
        "NSCameraUsageDescription": "ChefScale uses your camera to scan and photograph recipes, ingredient lists, and nutrition labels so you can quickly import them into the app for scaling and cost tracking.",
        "NSPhotoLibraryUsageDescription": "ChefScale accesses your photo library so you can import photos of recipes, ingredient lists, and nutrition labels for scanning and recipe entry.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.alstiginc.chefscale",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "3e4e4b74-5445-4e89-bba4-bc08387c178d"
      }
    }
  }
}
